generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── School & User ────────────────────────────────────────────────────────────

model School {
  id        Int      @id @default(autoincrement())
  name      String
  code      String?  @unique  // ตัวย่อโรงเรียน เช่น "hkbu" — ใช้ prefix username
  district  String
  province  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  users     User[]
}

model User {
  id                Int                @id @default(autoincrement())
  username          String             @unique
  password          String
  firstName         String
  lastName          String
  email             String
  role              String             // 'admin' | 'school_admin' | 'teacher' | 'student'
  schoolId          Int?
  school            School?            @relation(fields: [schoolId], references: [id])
  studentProfiles   StudentProfile[]
  firstLoginAt        DateTime?
  mustChangePassword  Boolean            @default(false)
  createdAt           DateTime           @default(now())

  pointTransactions PointTransaction[]
  dailyMissions     DailyMission[]
  timeTrialScores      TimeTrialScore[]
  saturdayQuizAttempts SaturdayQuizAttempt[]
}

// ─── Student ──────────────────────────────────────────────────────────────────

model StudentProfile {
  id              Int               @id @default(autoincrement())
  userId          Int
  user            User              @relation(fields: [userId], references: [id])
  academicYear    String            // เช่น "2567"
  school          String
  district        String
  province        String
  grade           String            // เช่น "ป.4" (legacy / manual override)
  enrollmentYear  String?           // ปีการศึกษาที่เริ่มชั้น enrollmentGrade เช่น "2567"
  enrollmentGrade String?           // "p1"|"p2"|"p3"|"p4"|"p5"|"p6"
  classroom       String?
  studentCode     String?
  status          String            @default("active") // "active" | "archived"
  createdAt       DateTime          @default(now())

  examResults       ExamResult[]
  examAnswers       ExamAnswer[]
  weakTopics        WeakTopicState[]
  sectionProgress   SectionProgress[]
  subtopicPasses    SubtopicPass[]
  topicPasses       TopicPass[]
  adaptiveWeaknesses AdaptiveWeakness[]
}

// ─── Exam Core ────────────────────────────────────────────────────────────────

model ExamResult {
  id               Int            @id @default(autoincrement())
  studentProfileId Int
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  mode             String         // 'practice' | 'timed' | 'mock' | 'remedial'
  examSetId        String?        // timed/mock เท่านั้น — อ้างอิง ExamSetMetadata.id
  sectionId        Int?           // practice เท่านั้น — อ้างอิง CurriculumSection.id
  score            Int?           // timed/mock เท่านั้น (คะแนนดิบ)
  totalScore       Int?           // timed/mock เท่านั้น (คะแนนเต็ม)
  correctCount     Int
  totalCount       Int
  durationSec      Int
  createdAt        DateTime       @default(now())
}

model ExamAnswer {
  id               Int            @id @default(autoincrement())
  studentProfileId Int
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  questionId       String
  question         Question       @relation(fields: [questionId], references: [id])
  selectedAnswer   String    // mc: 'a'|'b'|'c'|'d' — numeric: ตัวเลขเป็น string
  isCorrect        Boolean
  timeSec          Int?
  createdAt        DateTime       @default(now())

  @@index([studentProfileId])
}

model QuestionReport {
  id               Int      @id @default(autoincrement())
  questionId       String
  studentProfileId Int?
  reportType       String   // 'wrong_answer' | 'display_issue' | 'typo' | 'other'
  note             String?
  createdAt        DateTime @default(now())

  @@index([questionId])
}

model WeakTopicState {
  id               Int      @id @default(autoincrement())
  studentProfileId Int
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  topicTag         String
  subtopicTag      String?
  failCount        Int      @default(1)
  lastFailedAt     DateTime
  createdAt        DateTime @default(now())

  @@unique([studentProfileId, topicTag, subtopicTag])
}

model SectionProgress {
  id               Int            @id @default(autoincrement())
  studentProfileId Int
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  sectionId        Int
  isPassed         Boolean        @default(false)
  bestScore        Int
  passedAt         DateTime?
  updatedAt        DateTime       @updatedAt

  @@unique([studentProfileId, sectionId])
}

// ─── Question ─────────────────────────────────────────────────────────────────

model Question {
  id               String    @id @default(cuid())
  code             String?   @unique
  // รูปแบบ code: <grade>-<source>-<year>-<type>-q<NNN>[-<variant>]
  // เช่น "p6-pcc-2022-o-q001", "p6-pcc-2022-v-q001-02"

  textTh           String
  textEn           String
  image            String?
  content          Json?     // content blocks: [{type:'text',value:''} | {type:'image',url:''} | {type:'hint',label:'',content:[]}]
  type             String    @default("mc") // "mc" | "numeric"
  choices          Json      // [{ textTh, textEn, image? }]
  answer           String?   // mc: 'a'|'b'|'c'|'d' — numeric: null (ใช้ shortAnswer)
  shortAnswer      Json?     // numeric: ["42", "42.0"] — exact match
  attributes       Json
  // {
  //   "examGrade": "p5",
  //   "topic": ["topic:fractions"],
  //   "subtopic": ["subtopic:fractions-multiply"],
  //   "skill": ["skill:multi-step"],
  //   "trap": ["trap:wrong-unit"],
  //   "difficulty": 2,          // 1=ง่าย 2=กลาง 3=ยาก
  //   "estimatedTimeSec": 90,
  //   "score": 3,
  //   "questionNo": "001",
  //   "year": "2022"
  // }

  source           String?   // ชื่อชุดข้อสอบ/สนาม เช่น "Mock PCC ป.6"
  derivedFrom      String?   // code ของต้นฉบับ (กรณี variant) — legacy string ref

  // Question Family (ต้นฉบับ ↔ mock variants)
  parentQuestionId String?
  parent           Question?   @relation("QuestionVariants", fields: [parentQuestionId], references: [id])
  variants         Question[]  @relation("QuestionVariants")

  ownerOrg         String
  createdBy        String
  updatedBy        String
  aiGenerated      Boolean   @default(false)
  needsReview      Boolean   @default(false)
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  examAnswers        ExamAnswer[]
  saturdayQuizPools  SaturdayQuizPool[]
}

// ─── Exam Set & Curriculum ────────────────────────────────────────────────────

model ExamSetMetadata {
  id              String   @id @default(cuid())
  subject         String   @default("math") // "math" | "science" | "thai" | "english"
  grade           String   // "p4" | "p5" | "p6" | "m1" ...
  year            String?
  label           String?  // เช่น "สสวท ป.6 ปี 2558 (สอบคัดเลือกรอบที่ 1)"
  venueName       String?  // ชื่อสนามสั้น เช่น "สสวท", "จุฬาภรณ์"
  timeLimitSec    Int
  blueprint       Json     // [{ difficulty: 1|2|3, count: Int, topicTags?: String[] }]
  isOfficial      Boolean  // true = mock (ข้อสอบจริง), false = timed (จำลอง)
  questionSource     String?   // filter Question.source
  createdBy          String    // username ของ admin ที่สร้าง
  isActive           Boolean   @default(true)

  // Mock generation tracking
  mockGeneratedAt    DateTime? // null = ยังไม่ได้ mock, มีค่า = mock แล้ว
  mockQuestionCount  Int?      // จำนวนข้อ mock ที่ generate ได้จริง (text-only เท่านั้น)
}

model Curriculum {
  id         Int                 @id @default(autoincrement())
  grade      String              // "p4" | "p5" | "p6"
  chapterNo  Int
  titleTh    String
  titleEn    String
  isActive   Boolean             @default(true)
  sections   CurriculumSection[]
}

model CurriculumSection {
  id           Int        @id @default(autoincrement())
  curriculumId Int
  curriculum   Curriculum @relation(fields: [curriculumId], references: [id])
  sectionNo    Int
  titleTh      String
  titleEn      String
  topicTags    Json       // String[] เช่น ["topic:fractions", "subtopic:fractions-multiply"]
  isActive     Boolean    @default(true)
}

// ─── Classroom ────────────────────────────────────────────────────────────────

model ClassroomScoreUpload {
  id           Int      @id @default(autoincrement())
  uploadedById Int
  academicYear String?
  term         String?
  examPeriod   String?  // "midterm" | "final"
  school       String   @default("")
  grade        String?
  classroom    String?
  subject      String   @default("multi")
  scores       String   @default("[]") // JSON: [{ name, scores:{วิชา:คะแนน}, fullScore }]
  stats        String?  // JSON: [{ subject, mean, sd, count, passCount }]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Announcement ─────────────────────────────────────────────────────────────

model Announcement {
  id          Int                @id @default(autoincrement())
  title       String
  body        String
  targetRole  String?            // null=ทุกคน | 'student' | 'teacher'
  createdById Int
  isActive    Boolean            @default(true)
  expiresAt   DateTime?
  createdAt   DateTime           @default(now())
  reads       AnnouncementRead[]
}

model AnnouncementRead {
  id             Int          @id @default(autoincrement())
  userId         Int
  announcementId Int
  announcement   Announcement @relation(fields: [announcementId], references: [id])
  readAt         DateTime     @default(now())

  @@unique([userId, announcementId])
}

// ─── Gamification ─────────────────────────────────────────────────────────────

model CharacterState {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  level         Int      @default(1)
  totalXp       Int      @default(0)   // XP สะสมตลอดกาล (แสดงผล)
  activityXp    Int      @default(0)   // XP จาก daily/weekly/mission — reset ทุกปีการศึกษา
  permanentXp   Int      @default(0)   // XP จาก subtopic/topic pass — ไม่ reset
  currentStreak Int      @default(0)   // วันต่อเนื่องปัจจุบัน
  longestStreak Int      @default(0)
  lastActiveDate String?               // "YYYY-MM-DD" (ICT)
  updatedAt     DateTime @updatedAt
}

model PointTransaction {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  academicYear String
  type         String   // 'exam' | 'streak' | 'weekly_bonus' | 'parent_deduct' | 'admin_adjust'
  amount       Int      // บวก = ได้คะแนน, ลบ = เสียคะแนน
  note         String?
  createdAt    DateTime @default(now())
}

// DailyMission — จะ deprecate เมื่อ Gamification Phase 2 เสร็จ
model DailyMission {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  date           String   // "YYYY-MM-DD"
  questionsCount Int      @default(0)
  baseCompleted  Boolean  @default(false)
  pointsEarned   Int      @default(0)
  createdAt      DateTime @default(now())

  @@unique([userId, date])
}

// ─── Time Trial ───────────────────────────────────────────────────────────────

model TimeTrialScore {
  id           String   @id @default(cuid())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  weekKey      String   // "2026-W15" (ISO week)
  score        Int
  correctCount Int
  wrongCount   Int
  maxCombo     Int
  createdAt    DateTime @default(now())

  @@index([weekKey])
}

// ─── Ticket System ────────────────────────────────────────────────────────────

model TicketWallet {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
}

model TicketLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // 'earn_mission' | 'earn_box' | 'earn_admin' | 'use_competitive'
  amount    Int      // บวก = ได้ตั๋ว, ลบ = ใช้ตั๋ว
  note      String?
  createdAt DateTime @default(now())
}

model TicketDailyUsage {
  id        Int    @id @default(autoincrement())
  userId    Int
  date      String // "YYYY-MM-DD" (ICT, reset ตี 3)
  usedCount Int    @default(0)

  @@unique([userId, date])
}

// ─── Practice Pass Records ────────────────────────────────────────────────────

model SubtopicPass {
  id               Int            @id @default(autoincrement())
  studentProfileId Int
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  grade            String
  topicKey         String
  subtopicKey      String
  passedAt         DateTime       @default(now())

  @@unique([studentProfileId, grade, topicKey, subtopicKey])
}

model TopicPass {
  id               Int            @id @default(autoincrement())
  studentProfileId Int
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  grade            String
  topicKey         String
  passedAt         DateTime       @default(now())

  @@unique([studentProfileId, grade, topicKey])
}

// ─── Password Reset ───────────────────────────────────────────────────────────

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

// ─── Academic Record (ผลการเรียนจาก CSV โรงเรียน) ───────────────────────────

model AcademicRecord {
  id           Int      @id @default(autoincrement())
  // ข้อมูลนักเรียน (ใช้ match กับ User)
  firstName    String
  lastName     String
  school       String   // เช่น "ฮั่วเคี้ยวบุรีรัมย์"
  studentCode  String?  // รหัสนักเรียน (ถ้ามี)
  grade        String   // "p1"–"p6"
  classroom    String   // "1", "2", ...
  roomType     String   // "HKEP" | "GIFTED" | "มาตรฐาน"
  academicYear String   // "2568"
  term         String   @default("1")  // "1" | "2"
  // ข้อมูลรายวิชา
  subjectCode  String   // "ค11101"
  subjectName  String   // "คณิตศาสตร์"
  midScore     Float?
  finalScore   Float?
  totalScore   Float?
  gradeValue   String?  // "4.00", "3.50", ...
  createdAt    DateTime @default(now())

  @@index([firstName, lastName, school])
  @@index([studentCode, school])
}

// ─── Invite Code ─────────────────────────────────────────────────────────────

model InviteCode {
  id         Int       @id @default(autoincrement())
  code       String    @unique
  maxUses    Int       @default(1)
  usedCount  Int       @default(0)
  createdBy  String    // admin username
  note       String?   // หมายเหตุ เช่น "รุ่น 2568 ห้อง 6/1"
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
}

// ─── Feedback ─────────────────────────────────────────────────────────────────

model Feedback {
  id        Int      @id @default(autoincrement())
  name      String?  // ชื่อผู้ส่ง (optional)
  message   String   // ข้อความ
  page      String?  // URL หน้าที่ส่ง feedback
  userId    Int?     // user ที่ login อยู่ (optional)
  createdAt DateTime @default(now())
}

// ─── AttributeDictionary ──────────────────────────────────────────────────────

model AttributeDictionary {
  key      String @id  // เช่น "topic:fractions", "subtopic:fractions-multiply", "skill:multi-step"
  type     String      // "topic" | "subtopic" | "skill" | "trap"
  th       String      // ชื่อภาษาไทย
  en       String      // ชื่อภาษาอังกฤษ
  grade    Int?        // สำหรับ topic: ชั้นที่เกี่ยวข้อง (null = ข้ามชั้น)
  minGrade Int?        // สำหรับ subtopic/skill/trap: ชั้นต่ำสุดที่ใช้ได้

  @@map("attribute_dictionary")
}

// ─── Mission System ───────────────────────────────────────────────────────────

model MissionDailyLog {
  id           Int      @id @default(autoincrement())
  userId       Int
  date         String   // "YYYY-MM-DD" (ICT)
  correctCount Int      @default(0)  // จำนวนข้อที่ถูก (max 5)
  xpEarned     Int      @default(0)
  ticketEarned Int      @default(0)
  completedAt  DateTime?
  createdAt    DateTime @default(now())

  @@unique([userId, date])
}

model QuickQuizLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      String   // "YYYY-MM-DD" (ICT)
  setsCount Int      @default(0)  // กี่ชุดที่ทำแล้ว (max 3 ชุดได้ XP)
  xpEarned  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model WeeklyChallengeResult {
  id        Int      @id @default(autoincrement())
  userId    Int
  weekKey   String   // "2026-W18"
  attempts  Int      @default(0)
  bestScore Int      @default(0)  // จำนวนข้อถูกสูงสุด (max 10)
  xpEarned  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([userId, weekKey])
}

// ─── Leaderboard ──────────────────────────────────────────────────────────────

model LeaderboardSeason {
  id        Int      @id @default(autoincrement())
  name      String   // "Season 1 (2026)"
  startDate DateTime // วันแรกของ season (อาทิตย์)
  endDate   DateTime // วันสุดท้าย (ก่อนปิดเทอม)
  status    String   @default("active") // "active" | "offseason" | "closed"
  createdAt DateTime @default(now())

  periods   LeaderboardPeriod[]
}

model LeaderboardPeriod {
  id        Int               @id @default(autoincrement())
  seasonId  Int
  season    LeaderboardSeason @relation(fields: [seasonId], references: [id])
  type      String            // "weekly" | "monthly"
  weekKey   String?           // "2026-05-04" (วันอาทิตย์) สำหรับ weekly
  monthKey  String?           // "2026-M1" สำหรับ monthly
  label     String            // "สัปดาห์ที่ 1" / "เดือนที่ 1 (1–28 พ.ค)"
  startDate DateTime
  endDate   DateTime
  settled   Boolean           @default(false)

  @@index([type, weekKey])
  @@index([type, monthKey])
}

// Saturday Quiz — ข้อสอบ 10 ข้อประจำสัปดาห์ (เหมือนกันทุกคน)
model SaturdayQuizPool {
  id         Int      @id @default(autoincrement())
  weekKey    String   // "2026-05-04" (วันอาทิตย์ต้นสัปดาห์)
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  sortOrder  Int      // ลำดับที่แสดง (1–10)

  @@unique([weekKey, questionId])
  @@index([weekKey])
}

model SaturdayQuizAttempt {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  weekKey     String   // "2026-05-04"
  score       Int      // จำนวนข้อที่ถูก (0–10)
  timeUsed    Int      // วินาทีที่ใช้
  answers     Json     // { questionId: selectedAnswer, ... }
  completedAt DateTime @default(now())

  @@unique([userId, weekKey])
  @@index([weekKey])
}

// Hall of Fame — บันทึกถาวรหลัง settle
model HallOfFame {
  id          Int      @id @default(autoincrement())
  userId      Int
  periodId    Int
  activity    String   // "time_trial" | "saturday_quiz"
  totalScore  Int
  totalTime   Int?     // วินาทีรวม (tiebreak)
  rank        Int
  createdAt   DateTime @default(now())

  @@unique([userId, periodId, activity])
  @@index([periodId, activity])
}

// ─── Box System ───────────────────────────────────────────────────────────────

model BoxInventory {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  silverCount Int      @default(0)
  goldCount   Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model BoxLog {
  id           Int      @id @default(autoincrement())
  userId       Int
  boxType      String   // "silver"|"gold"
  rewardType   String   // "xp"|"parent_points"|"ticket"|"gold_box"|"digital"|"physical"
  rewardAmount Int?     // จำนวน XP / points / tickets
  rewardId     Int?     // อ้างอิง Reward ถ้าเป็น digital/physical
  createdAt    DateTime @default(now())
}

model Reward {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  type        String        // "digital"|"physical"
  code        String?       // สำหรับ digital reward (บัตรเติมเกม ฯลฯ)
  quantity    Int           @default(1)
  claimedQty  Int           @default(0)
  isActive    Boolean       @default(true)
  weekKey     String?       // ถ้าเป็น weekly prize: "2026-W18"
  league      String?       // "A"|"B"|"C"|null = ทุก league
  rank        Int?          // 1|2|3 = top rank ที่ได้รางวัลนี้
  createdBy   String
  createdAt   DateTime      @default(now())
  claims      RewardClaim[]
}

model RewardClaim {
  id          Int      @id @default(autoincrement())
  userId      Int
  rewardId    Int
  reward      Reward   @relation(fields: [rewardId], references: [id])
  claimRef    String   @unique  // "PRIZE-2026-0042"
  status      String   @default("pending")  // "pending"|"claimed"
  claimedAt   DateTime?
  claimedBy   String?  // admin username ที่ mark claimed
  createdAt   DateTime @default(now())
}

// ─── Parent Points ────────────────────────────────────────────────────────────

model ParentPointBalance {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  balance     Int      @default(0)
  totalEarned Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model ParentPointLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  amount    Int      // บวก = ได้, ลบ = หัก/แลกรางวัล
  note      String?  // เหตุผล เช่น "ทำ daily mission ครบ" | "ดูการ์ตูน 30 นาที"
  source    String   // "auto_login"|"auto_mission"|"auto_subtopic"|"auto_weekly"|"parent_manual"
  date      String   // "YYYY-MM-DD"
  createdAt DateTime @default(now())
}

// ─── Usage Tracking ───────────────────────────────────────────────────────────

// LoginLog — raw login events, ลบทุกคืนหลัง aggregate
model LoginLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  schoolId  Int?
  loginAt   DateTime @default(now())

  @@index([loginAt])
  @@index([userId])
}

// DailyUsageStat — aggregated stats (เก็บถาวร)
// grade/classroom = null → school-level aggregate
model DailyUsageStat {
  id                 Int      @id @default(autoincrement())
  date               String   // "YYYY-MM-DD"
  schoolId           Int?
  grade              String?  // null = school-level
  classroom          String?  // null = school-level
  activeUsers        Int      @default(0)
  questionsAnswered  Int      @default(0)
  createdAt          DateTime @default(now())

  @@unique([date, schoolId, grade, classroom])
  @@index([date, schoolId])
}

// ─── Adaptive Learning (ตะลุยโจทย์) ──────────────────────────────────────────

model AdaptiveWeakness {
  id               Int            @id @default(autoincrement())
  studentProfileId Int
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  tagType          String         // "topic" | "subtopic" | "skill" | "trap"
  tagKey           String         // เช่น "topic:fractions", "skill:multi-step"
  failCount        Int            @default(1)
  correctStreak    Int            @default(0)
  lastFailedAt     DateTime
  createdAt        DateTime       @default(now())

  @@unique([studentProfileId, tagKey])
}

# ========================================
# exam-app — Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่า
# ========================================

# ----- Required -----

# Session secret — ใส่ random string ยาวๆ เช่น openssl rand -base64 32
SESSION_SECRET=change-this-to-a-long-random-string

# ----- Database -----

# SQLite (default, ใช้ใน dev ไม่ต้องตั้ง)
# DATABASE_URL จะถูก Prisma อ่านจาก schema.prisma โดยอัตโนมัติ

# PostgreSQL (ถ้าต้องการ scale บน production)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ----- Cloudflare R2 (optional — ถ้าไม่ตั้งจะใช้ local uploads/) -----

# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET_NAME=exam-app-uploads
# R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev

# ----- App -----

NODE_ENV=production
PORT=3001

{
  "name": "exam-app",
  "version": "1.0.0",
  "description": "Online Exam App",
  "main": "server/index.js",
  "scripts": {
"build": "dotenv -e server/.env -- npx prisma generate --schema=server/prisma/schema.prisma && dotenv -e server/.env -- npx prisma migrate deploy --schema=server/prisma/schema.prisma",
  "dev": "nodemon server/index.js",
    "seed": "node prisma/seed.js",
  "prisma:generate": "dotenv -e server/.env -- npx prisma generate --schema=server/prisma/schema.prisma",
  "prisma:migrate": "dotenv -e server/.env -- npx prisma migrate deploy --schema=server/prisma/schema.prisma",

  "start": "node server/index.js"
  },

  "dependencies": {
    "@prisma/client": "6.11.1",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-session": "^1.18.1",
    "multer": "^1.4.5-lts.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^6.11.1"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

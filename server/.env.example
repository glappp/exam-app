# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Render / Supabase / local)
# ตัวอย่าง: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# ─── Session ──────────────────────────────────────────────────────────────────
# สุ่มสตริงยาวๆ สำหรับ production
SESSION_SECRET="change-me-to-a-long-random-string"

# ─── Cloudflare R2 (Images) ───────────────────────────────────────────────────
# ถ้าไม่ตั้งค่า → เก็บ local uploads/ (dev only)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="schoolpl-assets"
# Public URL ของ bucket (เปิด Public Access บน R2 แล้ว)
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxxxxxxxxxx.r2.dev"

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=3001

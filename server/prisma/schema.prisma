generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── School & User ────────────────────────────────────────────────────────────

model School {
  id        Int      @id @default(autoincrement())
  name      String
  district  String
  province  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  users     User[]
}

model User {
  id                Int                @id @default(autoincrement())
  username          String             @unique
  password          String
  firstName         String
  lastName          String
  email             String
  role              String             // 'admin' | 'school_admin' | 'teacher' | 'student'
  schoolId          Int?
  school            School?            @relation(fields: [schoolId], references: [id])
  studentProfiles   StudentProfile[]
  firstLoginAt      DateTime?
  createdAt         DateTime           @default(now())

  pointTransactions PointTransaction[]
  dailyMissions     DailyMission[]
  timeTrialScores   TimeTrialScore[]
}

// ─── Student ──────────────────────────────────────────────────────────────────

model StudentProfile {
  id            Int               @id @default(autoincrement())
  userId        Int
  user          User              @relation(fields: [userId], references: [id])
  academicYear  String            // เช่น "2567"
  school        String
  district      String
  province      String
  grade         String            // เช่น "ป.4"
  classroom     String?
  studentCode   String?
  status        String            @default("active") // "active" | "archived"
  createdAt     DateTime          @default(now())

  examResults     ExamResult[]
  examAnswers     ExamAnswer[]
  weakTopics      WeakTopicState[]
  sectionProgress SectionProgress[]
  subtopicPasses  SubtopicPass[]
  topicPasses     TopicPass[]
}

// ─── Exam Core ────────────────────────────────────────────────────────────────

model ExamResult {
  id               Int            @id @default(autoincrement())
  studentProfileId Int
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  mode             String         // 'practice' | 'timed' | 'mock' | 'remedial'
  examSetId        String?        // timed/mock เท่านั้น — อ้างอิง ExamSetMetadata.id
  sectionId        Int?           // practice เท่านั้น — อ้างอิง CurriculumSection.id
  score            Int?           // timed/mock เท่านั้น (คะแนนดิบ)
  totalScore       Int?           // timed/mock เท่านั้น (คะแนนเต็ม)
  correctCount     Int
  totalCount       Int
  durationSec      Int
  createdAt        DateTime       @default(now())
}

model ExamAnswer {
  id               Int            @id @default(autoincrement())
  studentProfileId Int
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  questionId       String
  question         Question       @relation(fields: [questionId], references: [id])
  selectedAnswer   String    // mc: 'a'|'b'|'c'|'d' — numeric: ตัวเลขเป็น string
  isCorrect        Boolean
  timeSec          Int?
  createdAt        DateTime       @default(now())

  @@index([studentProfileId])
}

model QuestionReport {
  id               Int      @id @default(autoincrement())
  questionId       String
  studentProfileId Int?
  reportType       String   // 'wrong_answer' | 'display_issue' | 'typo' | 'other'
  note             String?
  createdAt        DateTime @default(now())

  @@index([questionId])
}

model WeakTopicState {
  id               Int      @id @default(autoincrement())
  studentProfileId Int
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  topicTag         String
  subtopicTag      String?
  failCount        Int      @default(1)
  lastFailedAt     DateTime
  createdAt        DateTime @default(now())

  @@unique([studentProfileId, topicTag, subtopicTag])
}

model SectionProgress {
  id               Int            @id @default(autoincrement())
  studentProfileId Int
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  sectionId        Int
  isPassed         Boolean        @default(false)
  bestScore        Int
  passedAt         DateTime?
  updatedAt        DateTime       @updatedAt

  @@unique([studentProfileId, sectionId])
}

// ─── Question ─────────────────────────────────────────────────────────────────

model Question {
  id               String    @id @default(cuid())
  code             String?   @unique
  // รูปแบบ code: <grade>-<source>-<year>-<type>-q<NNN>[-<variant>]
  // เช่น "p6-pcc-2022-o-q001", "p6-pcc-2022-v-q001-02"

  textTh           String
  textEn           String
  image            String?
  content          Json?     // content blocks: [{type:'text',value:''} | {type:'image',url:''} | {type:'hint',label:'',content:[]}]
  type             String    @default("mc") // "mc" | "numeric"
  choices          Json      // [{ textTh, textEn, image? }]
  answer           String?   // mc: 'a'|'b'|'c'|'d' — numeric: null (ใช้ shortAnswer)
  shortAnswer      Json?     // numeric: ["42", "42.0"] — exact match
  attributes       Json
  // {
  //   "examGrade": "p5",
  //   "topic": ["topic:fractions"],
  //   "subtopic": ["subtopic:fractions-multiply"],
  //   "skill": ["skill:multi-step"],
  //   "trap": ["trap:wrong-unit"],
  //   "difficulty": 2,          // 1=ง่าย 2=กลาง 3=ยาก
  //   "estimatedTimeSec": 90,
  //   "score": 3,
  //   "questionNo": "001",
  //   "year": "2022"
  // }

  source           String?   // ชื่อชุดข้อสอบ/สนาม เช่น "Mock PCC ป.6"
  derivedFrom      String?   // code ของต้นฉบับ (กรณี variant)
  ownerOrg         String
  createdBy        String
  updatedBy        String
  aiGenerated      Boolean   @default(false)
  needsReview      Boolean   @default(false)
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  examAnswers      ExamAnswer[]
}

// ─── Exam Set & Curriculum ────────────────────────────────────────────────────

model ExamSetMetadata {
  id              String   @id @default(cuid())
  grade           String   // "p4" | "p5" | "p6" | "m1" ...
  year            String?
  label           String?  // เช่น "จุฬาภรณ์ ป.6 ปี 2565"
  timeLimitSec    Int
  blueprint       Json     // [{ difficulty: 1|2|3, count: Int, topicTags?: String[] }]
  isOfficial      Boolean  // true = mock (ข้อสอบจริง), false = timed (จำลอง)
  questionSource  String?  // filter Question.source
  createdBy       String   // username ของ admin ที่สร้าง
  isActive        Boolean  @default(true)
}

model Curriculum {
  id         Int                 @id @default(autoincrement())
  grade      String              // "p4" | "p5" | "p6"
  chapterNo  Int
  titleTh    String
  titleEn    String
  isActive   Boolean             @default(true)
  sections   CurriculumSection[]
}

model CurriculumSection {
  id           Int        @id @default(autoincrement())
  curriculumId Int
  curriculum   Curriculum @relation(fields: [curriculumId], references: [id])
  sectionNo    Int
  titleTh      String
  titleEn      String
  topicTags    Json       // String[] เช่น ["topic:fractions", "subtopic:fractions-multiply"]
  isActive     Boolean    @default(true)
}

// ─── Classroom ────────────────────────────────────────────────────────────────

model ClassroomScoreUpload {
  id           Int      @id @default(autoincrement())
  uploadedById Int
  academicYear String?
  term         String?
  examPeriod   String?  // "midterm" | "final"
  school       String   @default("")
  grade        String?
  classroom    String?
  subject      String   @default("multi")
  scores       String   @default("[]") // JSON: [{ name, scores:{วิชา:คะแนน}, fullScore }]
  stats        String?  // JSON: [{ subject, mean, sd, count, passCount }]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Announcement ─────────────────────────────────────────────────────────────

model Announcement {
  id          Int                @id @default(autoincrement())
  title       String
  body        String
  targetRole  String?            // null=ทุกคน | 'student' | 'teacher'
  createdById Int
  isActive    Boolean            @default(true)
  expiresAt   DateTime?
  createdAt   DateTime           @default(now())
  reads       AnnouncementRead[]
}

model AnnouncementRead {
  id             Int          @id @default(autoincrement())
  userId         Int
  announcementId Int
  announcement   Announcement @relation(fields: [announcementId], references: [id])
  readAt         DateTime     @default(now())

  @@unique([userId, announcementId])
}

// ─── Gamification ─────────────────────────────────────────────────────────────

model CharacterState {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  level     Int      @default(1)
  totalXp   Int      @default(0)
  updatedAt DateTime @updatedAt
}

model PointTransaction {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  academicYear String
  type         String   // 'exam' | 'streak' | 'weekly_bonus' | 'parent_deduct' | 'admin_adjust'
  amount       Int      // บวก = ได้คะแนน, ลบ = เสียคะแนน
  note         String?
  createdAt    DateTime @default(now())
}

// DailyMission — จะ deprecate เมื่อ Gamification Phase 2 เสร็จ
model DailyMission {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  date           String   // "YYYY-MM-DD"
  questionsCount Int      @default(0)
  baseCompleted  Boolean  @default(false)
  pointsEarned   Int      @default(0)
  createdAt      DateTime @default(now())

  @@unique([userId, date])
}

// ─── Time Trial ───────────────────────────────────────────────────────────────

model TimeTrialScore {
  id           String   @id @default(cuid())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  weekKey      String   // "2026-W15" (ISO week)
  score        Int
  correctCount Int
  wrongCount   Int
  maxCombo     Int
  createdAt    DateTime @default(now())

  @@index([weekKey])
}

// ─── Ticket System ────────────────────────────────────────────────────────────

model TicketWallet {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
}

model TicketLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // 'earn_mission' | 'earn_box' | 'earn_admin' | 'use_competitive'
  amount    Int      // บวก = ได้ตั๋ว, ลบ = ใช้ตั๋ว
  note      String?
  createdAt DateTime @default(now())
}

model TicketDailyUsage {
  id        Int    @id @default(autoincrement())
  userId    Int
  date      String // "YYYY-MM-DD" (ICT, reset ตี 3)
  usedCount Int    @default(0)

  @@unique([userId, date])
}

// ─── Practice Pass Records ────────────────────────────────────────────────────

model SubtopicPass {
  id               Int            @id @default(autoincrement())
  studentProfileId Int
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  grade            String
  topicKey         String
  subtopicKey      String
  passedAt         DateTime       @default(now())

  @@unique([studentProfileId, grade, topicKey, subtopicKey])
}

model TopicPass {
  id               Int            @id @default(autoincrement())
  studentProfileId Int
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  grade            String
  topicKey         String
  passedAt         DateTime       @default(now())

  @@unique([studentProfileId, grade, topicKey])
}

// ─── AttributeDictionary ──────────────────────────────────────────────────────

model AttributeDictionary {
  key      String @id  // เช่น "topic:fractions", "subtopic:fractions-multiply", "skill:multi-step"
  type     String      // "topic" | "subtopic" | "skill" | "trap"
  th       String      // ชื่อภาษาไทย
  en       String      // ชื่อภาษาอังกฤษ
  grade    Int?        // สำหรับ topic: ชั้นที่เกี่ยวข้อง (null = ข้ามชั้น)
  minGrade Int?        // สำหรับ subtopic/skill/trap: ชั้นต่ำสุดที่ใช้ได้

  @@map("attribute_dictionary")
}

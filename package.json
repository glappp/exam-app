{
  "name": "exam-app",
  "version": "1.0.0",
  "description": "Online Exam App",
  "main": "server/index.js",
  "scripts": {
    "postinstall": "node node_modules/prisma/build/index.js generate --schema=server/prisma/schema.prisma",
    "build": "node node_modules/prisma/build/index.js generate --schema=server/prisma/schema.prisma && node node_modules/prisma/build/index.js migrate deploy --schema=server/prisma/schema.prisma",
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "prisma:generate": "node node_modules/prisma/build/index.js generate --schema=server/prisma/schema.prisma",
    "prisma:migrate": "node node_modules/prisma/build/index.js migrate deploy --schema=server/prisma/schema.prisma",
    "seed": "node server/prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "6.11.1",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-session": "^1.18.1",
    "multer": "^1.4.5-lts.1",
    "prisma": "6.11.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "dotenv-cli": "^7.0.0",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "prisma": {
    "seed": "node server/prisma/seed.js"
  }
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int              @id @default(autoincrement())
  username        String           @unique
  password        String
  firstName       String
  lastName        String
  email           String
  role            String
  createdAt       DateTime         @default(now())
  results         Result[]
  studentProfiles StudentProfile[]
}

model StudentProfile {
  id           Int          @id @default(autoincrement())
  userId       Int
  academicYear String
  school       String
  district     String
  province     String
  grade        String
  classroom    String?
  studentCode  String?
  createdAt    DateTime     @default(now())
  examResults  ExamResult[]
  user         User         @relation(fields: [userId], references: [id])
}

model ExamResult {
  id               Int            @id @default(autoincrement())
  studentProfileId Int
  mode             String
  examSetCode      String?
  topicTagsJson    Json
  questionIds      Json
  userAnswers      Json
  score            Int
  total            Int
  durationSec      Int
  weakAttributes   Json?
  createdAt        DateTime       @default(now())
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
}

model Question {
  id               String   @id @default(cuid())
  code             String?  @unique
  textTh           String
  textEn           String
  image            String?
  choices          Json
  answer           Int?
  shortAnswer      Json?
  attributes       Json
  source           String?
  derivedFrom      String?
  estimatedTimeSec Int?
  score            Int?
  ownerOrg         String
  createdBy        String
  updatedBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  results          Result[]
}

model Result {
  id         Int      @id @default(autoincrement())
  questionId String
  userId     Int?
  selected   String
  correct    Boolean
  createdAt  DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
}

model ExamSetMetadata {
  id            String  @id @default(cuid())
  examType      String
  year          String?
  grade         String
  questionCount Int
  timeLimitSec  Int
  isOfficial    Boolean
  label         String?
  isActive      Boolean @default(true)
}

model Topic {
  id        String        @id
  labelTh   String
  labelEn   String
  grade     String        // P4, P5, P6
  skills    TopicSkill[]
}

model Skill {
  id        String        @id
  labelTh   String
  labelEn   String
  grade     String?       // optional: บาง skill เจาะจง grade เดียว
  topics    TopicSkill[]
}

model TopicSkill {
  id        Int      @id @default(autoincrement())
  topic     Topic    @relation(fields: [topicId], references: [id])
  topicId   String
  skill     Skill    @relation(fields: [skillId], references: [id])
  skillId   String

  @@unique([topicId, skillId])
}

model Trap {
  id        String   @id
  labelTh   String
  labelEn   String
}






/// 🗂️ AttributeDictionary (HK Project)
///
/// ใช้เก็บชุดคำศัพท์กลางของ attribute สำหรับระบบคลังข้อสอบ (HK Project)
/// เช่น topic:area-grade4, skill:mental-math, trap:misread
///
/// จุดประสงค์:
/// - ใช้เป็น canonical dictionary เพื่อป้องกันการตั้งชื่อซ้ำซ้อน
/// - ใช้ให้ AI เลือกจาก attribute เดิม ไม่เดาใหม่
/// - ใช้แสดงผลชื่อไทย/อังกฤษใน frontend
/// - ใช้วิเคราะห์จุดอ่อนของผู้เรียนแบบละเอียด
///
/// หมายเหตุ:
/// - `type` = "topic", "skill", หรือ "trap"
/// - `grade` จะใส่เฉพาะ topic เท่านั้น เช่น 4, 5, 6
model AttributeDictionary {
  /// รหัสคีย์ เช่น "topic:area-grade4"
  key   String @id
  /// ประเภทของ attribute: topic, skill, trap
  type  String
  /// ชื่อภาษาไทย เช่น "พื้นที่ (ป.4)"
  th    String
  /// ชื่อภาษาอังกฤษ เช่น "Area (Grade 4)"
  en    String
  /// ชั้นเรียนที่เกี่ยวข้อง เช่น 4, 5, 6 (เฉพาะ topic เท่านั้น)
  grade Int?

  @@map("attribute_dictionary")
}
